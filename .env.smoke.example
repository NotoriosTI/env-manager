# Smoke test GCP credentials
# Copy to .env.smoke (gitignored) and fill in real values.
# Without this file the GCP cases run with a mock loader.

# Your GCP project ID
SMOKE_GCP_PROJECT_ID=your-project-id

# The smoke test expects GCP secrets named after each APP_DB_* variable.
# Create them with (repeat for each):
#   echo -n "appdb"               | gcloud secrets create APP_DB_NAME     --data-file=-
#   echo -n "127.0.0.1"          | gcloud secrets create APP_DB_HOST     --data-file=-
#   echo -n "5432"               | gcloud secrets create APP_DB_PORT     --data-file=-
#   echo -n "app_admin"          | gcloud secrets create APP_DB_USER     --data-file=-
#   echo -n "your-password-here" | gcloud secrets create APP_DB_PASSWORD --data-file=-
